def move_latest_file(source_dir, target_dir, new_name):
    """Searches source for most recent excel/csv and moves it to target."""
    files = [os.path.join(source_dir, f) for f in os.listdir(source_dir) if f.endswith(('.xls', '.xlsx', '.csv'))]
    if not files:
        return False
    latest_file = max(files, key=os.path.getmtime)
    target_path = Path(target_dir) / new_name
    os.makedirs(target_dir, exist_ok=True)
    shutil.move(latest_file, target_path)
    return True

def save_with_retries(workbook, path: Path, max_retries: int = 5, delay_sec: float = 1.0):
    """Safely saves Excel even if it's currently open by the user."""
    for attempt in range(1, max_retries + 1):
        try:
            workbook.save(path)
            return True
        except PermissionError:
            print(f"   > Save blocked. Retry {attempt}/{max_retries}...")
            time.sleep(delay_sec)
    
    # Emergency backup if primary save fails
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    backup = path.with_name(f"{path.stem}_autosave_{ts}{path.suffix}")
    workbook.save(backup)
    print(f"   > Saved to backup: {backup.name}")
    return False

